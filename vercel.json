{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/data/:file", "destination": "/public/data/:file" },
    { "source": "/archive/:slug", "destination": "/index.html" }
  ]
}
